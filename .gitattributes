# Normalize line endings: LF in the repo, whatever the OS wants on checkout.
* text=auto eol=lf

# Go / TS / Svelte / docs / scripts: enforce LF.
*.go        text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.svelte    text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
Makefile    text eol=lf
*.ps1       text eol=crlf
*.nsi       text eol=crlf

# Binaries
*.exe   binary
*.ico   binary
*.zip   binary
